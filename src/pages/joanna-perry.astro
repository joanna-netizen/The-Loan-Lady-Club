---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Joanna Perry | Mortgage Broker in Sacramento, CA | The Loan Lady Club | NMLS 243348"
  description="Joanna Perry is a California mortgage broker and founder of The Loan Lady Club. Serving homebuyers and homeowners throughout Sacramento and Northern California with an education-first approach to lending. NMLS 243348."
  canonical="https://loanladyclub.com/joanna-perry"
  ogImage="/images/joanna-perry-mortgage-broker-sacramento-loan-lady-club-headshot.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Joanna Perry",
  "url": "https://loanladyclub.com/joanna-perry",
  "image": "https://loanladyclub.com/images/joanna-perry-mortgage-broker-sacramento-loan-lady-club-headshot.jpg",
  "jobTitle": "Mortgage Broker",
  "description": "Joanna Perry is a mortgage broker in Sacramento, California and founder of The Loan Lady Club. NMLS 243348.",
  "worksFor": {
    "@type": "Organization",
    "name": "The Loan Lady Club",
    "url": "https://loanladyclub.com"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sacramento",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "sameAs": [
    "https://loanladyclub.com/about"
  ]
}
    </script>

    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://loanladyclub.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Joanna Perry",
      "item": "https://loanladyclub.com/joanna-perry"
    }
  ]
}
    </script>

    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is Joanna Perry?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Joanna Perry is a California-licensed mortgage broker with 15 plus years of experience and the founder of The Loan Lady Club, based in Sacramento, California. NMLS 243348."
