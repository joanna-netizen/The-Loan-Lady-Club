      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Joanna Perry specializes in FHA, VA, CalHFA, DSCR, Non-QM, Digital HELOC, and first-time homebuyer programs. She is known for her education-first approach and her proprietary Buyer's Edge pre-underwriting process."
      }
    },
    {
      "@type": "Question",
      "name": "Where does Joanna Perry work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Joanna Perry is the founder and senior mortgage broker at The Loan Lady Club, located at 9278 Madison Ave, Orangevale, CA 95662, powered by Xpert Home Lending Inc, NMLS 2179191."
      }
